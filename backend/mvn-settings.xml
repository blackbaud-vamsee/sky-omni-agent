<!--
  Project-local Maven settings for SKY-Omni Agent hackathon POC.
  Routes all artifact downloads to Maven Central (HTTPS) directly,
  bypassing the corporate Nexus which uses HTTP (blocked by Maven 3.8+).
  Also overrides the corporate local repository path.

  Usage:
    mvn -s /home/vamseekrushna/Documents/OTG/sky-omni-agent/backend/mvn-settings.xml spring-boot:run
-->
<settings>
  <localRepository>/home/vamseekrushna/.m2/repository</localRepository>
  <mirrors>
    <mirror>
      <id>central-https</id>
      <mirrorOf>*</mirrorOf>
      <url>https://repo1.maven.org/maven2</url>
    </mirror>
  </mirrors>
</settings>
